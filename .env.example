# =============================================================================
# ClawScout v1 — Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# App
APP_NAME=ClawScout
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=clawscout
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clawscout
DATABASE_URL=postgresql://clawscout:changeme@localhost:5432/clawscout

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Ollama / LLM
# In WSL/Linux-first, prefer the WSL-facing bridge URL printed by:
#   bash scripts/ensure-ollama-bridge.sh --print-url
OLLAMA_BASE_URL=http://localhost:11434
# Legacy fallback for the executor role. Keep this set for backward compatibility.
OLLAMA_MODEL=qwen3.5:9b
# Supported catalog for role-based routing
OLLAMA_SUPPORTED_MODELS=qwen3.5:4b,qwen3.5:9b,qwen3.5:27b
# Role-based model selection
OLLAMA_LEADER_MODEL=qwen3.5:4b
# If omitted, executor falls back to OLLAMA_MODEL
OLLAMA_EXECUTOR_MODEL=qwen3.5:9b
OLLAMA_REVIEWER_MODEL=qwen3.5:27b
OLLAMA_TIMEOUT=120
OLLAMA_REVIEWER_TIMEOUT=360
OLLAMA_MAX_RETRIES=3

# Crawling
CRAWLER_RATE_LIMIT_PER_SECOND=1
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3
CRAWLER_USER_AGENT=ClawScout/1.0 (research)

# Outreach (v1: no auto-send)
OUTREACH_AUTO_SEND=false

# Mail (v1: explicit single-draft send only)
MAIL_PROVIDER=smtp
MAIL_ENABLED=false
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=ClawScout
MAIL_REPLY_TO=
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_SSL=false
MAIL_SEND_TIMEOUT=30
MAIL_INBOUND_PROVIDER=imap
MAIL_INBOUND_ENABLED=false
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_USERNAME=
MAIL_IMAP_PASSWORD=
MAIL_IMAP_SSL=true
MAIL_IMAP_MAILBOX=INBOX
MAIL_IMAP_SEARCH_CRITERIA=ALL
MAIL_INBOUND_SYNC_LIMIT=25
MAIL_INBOUND_TIMEOUT=30
MAIL_AUTO_CLASSIFY_INBOUND=false
MAIL_USE_REVIEWER_FOR_LABELS=

# Rate limiting (API)
API_RATE_LIMIT=60/minute

# Frontend / dashboard (browser origins allowed to call the API)
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
