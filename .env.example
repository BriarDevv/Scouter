# =============================================================================
# ClawScout v1 — Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# App
APP_NAME=ClawScout
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=clawscout
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clawscout
DATABASE_URL=postgresql://clawscout:changeme@localhost:5432/clawscout

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Ollama / LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# Crawling
CRAWLER_RATE_LIMIT_PER_SECOND=1
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3
CRAWLER_USER_AGENT=ClawScout/1.0 (research)

# Outreach (v1: no auto-send)
OUTREACH_AUTO_SEND=false

# Rate limiting (API)
API_RATE_LIMIT=60/minute
