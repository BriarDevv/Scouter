# =============================================================================
# ClawScout v1 — Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# App
APP_NAME=ClawScout
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=clawscout
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clawscout
DATABASE_URL=postgresql://clawscout:changeme@localhost:5432/clawscout

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Ollama / LLM
OLLAMA_BASE_URL=http://localhost:11434
# Legacy fallback for the executor role. Keep this set for backward compatibility.
OLLAMA_MODEL=qwen3.5:9b
# Supported catalog for role-based routing
OLLAMA_SUPPORTED_MODELS=qwen3.5:4b,qwen3.5:9b,qwen3.5:27b
# Role-based model selection
OLLAMA_LEADER_MODEL=qwen3.5:4b
# If omitted, executor falls back to OLLAMA_MODEL
OLLAMA_EXECUTOR_MODEL=qwen3.5:9b
OLLAMA_REVIEWER_MODEL=qwen3.5:27b
OLLAMA_TIMEOUT=120
OLLAMA_REVIEWER_TIMEOUT=360
OLLAMA_MAX_RETRIES=3

# Crawling
CRAWLER_RATE_LIMIT_PER_SECOND=1
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3
CRAWLER_USER_AGENT=ClawScout/1.0 (research)

# Outreach (v1: no auto-send)
OUTREACH_AUTO_SEND=false

# Rate limiting (API)
API_RATE_LIMIT=60/minute

# Frontend / dashboard (browser origins allowed to call the API)
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
