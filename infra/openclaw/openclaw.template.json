{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "__OLLAMA_BASE_URL__",
        "api": "ollama",
        "models": [
          {
            "id": "__LEADER_MODEL_ID__",
            "name": "Leader Model",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          },
          {
            "id": "__EXECUTOR_MODEL_ID__",
            "name": "Executor Model",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          },
          {
            "id": "__REVIEWER_MODEL_ID__",
            "name": "Reviewer Model",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "__WORKSPACE_PATH__",
      "model": {
        "primary": "ollama/__LEADER_MODEL_ID__"
      },
      "models": {
        "ollama/__LEADER_MODEL_ID__": {
          "alias": "leader"
        },
        "ollama/__EXECUTOR_MODEL_ID__": {
          "alias": "executor"
        },
        "ollama/__REVIEWER_MODEL_ID__": {
          "alias": "reviewer"
        }
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  }
}
