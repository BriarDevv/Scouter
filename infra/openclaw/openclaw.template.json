{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "__OLLAMA_BASE_URL__",
        "api": "ollama",
        "models": [
          {
            "id": "__LEADER_MODEL_ID__",
            "name": "Leader Model",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          },
          {
            "id": "__EXECUTOR_MODEL_ID__",
            "name": "Executor Model",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          },
          {
            "id": "__REVIEWER_MODEL_ID__",
            "name": "Reviewer Model",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "__WORKSPACE_PATH__",
      "timeoutSeconds": __OPENCLAW_TIMEOUT_SECONDS__,
      "bootstrapMaxChars": 1,
      "bootstrapTotalMaxChars": 1,
      "bootstrapPromptTruncationWarning": "off",
      "model": {
        "primary": "ollama/__LEADER_MODEL_ID__"
      },
      "models": {
        "ollama/__LEADER_MODEL_ID__": {
          "alias": "leader"
        },
        "ollama/__EXECUTOR_MODEL_ID__": {
          "alias": "executor"
        },
        "ollama/__REVIEWER_MODEL_ID__": {
          "alias": "reviewer"
        }
      },
      "compaction": {
        "mode": "safeguard",
        "postCompactionSections": []
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "skills": {
    "allowBundled": [],
    "load": {
      "watch": true,
      "watchDebounceMs": 250
    },
    "entries": {
      "clawscout-leader": {
        "env": {
          "CLAWSCOUT_API_BASE_URL": "__CLAWSCOUT_API_BASE_URL__"
        }
      },
      "clawscout-mail": {
        "env": {
          "CLAWSCOUT_API_BASE_URL": "__CLAWSCOUT_API_BASE_URL__"
        }
      },
      "clawscout-browser": {
        "env": {
          "CLAWSCOUT_API_BASE_URL": "__CLAWSCOUT_API_BASE_URL__"
        }
      }
    }
  },
  "tools": {
    "allow": [
      "exec"
    ]
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  }
}
